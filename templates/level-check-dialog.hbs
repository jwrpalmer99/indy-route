<div class="traveler-level-check-inner">

  {{!-- Header: mode icon + actor / check title --}}
  <header class="tlcd-header">
    <i class="tlcd-mode-icon {{modeIcon}}" title="{{modeName}}"></i>
    <div class="tlcd-header-text">
      <h3 class="tlcd-check-label">{{checkLabel}}</h3>
      <p class="tlcd-actor-name">{{actorName}} must make a check to proceed.</p>
    </div>
  </header>

  {{!-- Details: formula and DC --}}
  <div class="tlcd-details">
    <div class="tlcd-detail">
      <span class="tlcd-detail-label">Roll</span>
      <code class="tlcd-detail-value">{{formula}}</code>
    </div>
    <div class="tlcd-detail tlcd-detail--dc">
      <span class="tlcd-detail-label">DC</span>
      <span class="tlcd-detail-value">{{dc}}</span>
    </div>
  </div>

  {{!-- Actions --}}
  <div class="tlcd-actions">
    <button type="button" data-action="give-up" class="tlcd-btn tlcd-btn--secondary">
      <i class="fa-solid fa-xmark"></i> Give Up
    </button>
    <button type="button" data-action="attempt" class="tlcd-btn tlcd-btn--primary">
      <i class="fa-solid fa-dice-d20"></i> Attempt
    </button>
  </div>

</div>

<style>
  /* Scoped to this dialog's content */
  .traveler-level-check-dialog .window-content {
    padding: 0;
  }
  .traveler-level-check-inner {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px;
    font-family: var(--font-primary, inherit);
  }
  .tlcd-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .tlcd-mode-icon {
    font-size: 2rem;
    color: var(--color-border-highlight, #ff6400);
    flex-shrink: 0;
  }
  .tlcd-header-text {
    flex: 1;
    min-width: 0;
  }
  .tlcd-check-label {
    margin: 0 0 2px;
    font-size: 1em;
    font-weight: 700;
    line-height: 1.2;
  }
  .tlcd-actor-name {
    margin: 0;
    font-size: 0.8em;
    color: var(--color-text-light-6, #888);
  }
  .tlcd-details {
    display: flex;
    gap: 8px;
  }
  .tlcd-detail {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 4px;
    background: var(--color-bg, rgba(0,0,0,0.05));
    border: 1px solid var(--color-border-light-2, #aaa);
    border-radius: 6px;
  }
  .tlcd-detail--dc {
    flex: 0 0 80px;
  }
  .tlcd-detail-label {
    font-size: 0.7em;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-light-7, #999);
    margin-bottom: 2px;
  }
  .tlcd-detail-value {
    font-size: 1em;
    font-weight: 600;
  }
  .tlcd-actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }
  .tlcd-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 14px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.9em;
    font-weight: 600;
    transition: filter 0.15s;
  }
  .tlcd-btn:hover {
    filter: brightness(1.15);
  }
  .tlcd-btn--primary {
    background: var(--color-border-highlight, #ff6400);
    color: #fff;
  }
  .tlcd-btn--secondary {
    background: var(--color-bg, rgba(0,0,0,0.12));
    color: var(--color-text-dark-primary, #333);
    border: 1px solid var(--color-border-light-2, #bbb);
  }
</style>
