<div class="party-collector-wrap">
  <div class="collector-header">
    <span class="check-label">{{checkLabel}}</span>
    <span class="check-dc">DC {{dc}}</span>
    <span class="mode-label">{{modeName}}</span>
  </div>

  <table class="roll-table">
    <thead>
      <tr>
        <th>Member</th>
        <th>Result</th>
      </tr>
    </thead>
    <tbody>
      {{#each rows}}
      <tr class="roll-row status-{{status}}{{#if cancelled}} cancelled{{/if}}">
        <td class="actor-name">{{actorName}}</td>
        <td class="roll-result">
          <i class="{{icon}}"></i>
          <span>{{statusLabel}}</span>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  {{#if resolved}}
  <div class="resolved-banner {{#if allPassed}}pass{{else}}fail{{/if}}">
    {{#if allPassed}}
      <i class="fa-solid fa-check-circle"></i> Party passes — movement continues
    {{else}}
      <i class="fa-solid fa-times-circle"></i> Party blocked — movement stopped
    {{/if}}
  </div>
  {{else}}
  <div class="collector-footer">
    <span class="waiting-note">
      <i class="fa-solid fa-spinner fa-spin"></i>
      Waiting for {{rows.length}} roll{{#if (ne rows.length 1)}}s{{/if}}…
    </span>
    {{#unless allDone}}
    <button type="button" data-action="force-resolve" class="btn-force">
      Force Resolve
    </button>
    {{/unless}}
  </div>
  {{/if}}
</div>

<style>
  .party-collector-wrap { padding: 8px; font-size: 13px; }
  .collector-header { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid #ddd; }
  .check-label { font-weight: 700; font-size: 14px; }
  .check-dc { background: #444; color: #fff; border-radius: 4px; padding: 1px 6px; font-size: 11px; }
  .mode-label { font-size: 11px; color: #666; margin-left: auto; font-style: italic; }
  .roll-table { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
  .roll-table th { text-align: left; padding: 4px 6px; background: #f0f0f0; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; }
  .roll-row td { padding: 5px 6px; border-bottom: 1px solid #eee; }
  .roll-row.status-pending .roll-result { color: #999; }
  .roll-row.status-rolled:not(.cancelled) .roll-result .text-success { color: #27ae60; }
  .roll-row.status-rolled:not(.cancelled) .roll-result .text-failure { color: #c0392b; }
  .roll-row.cancelled .roll-result { color: #c0392b; }
  .roll-row.status-timeout .roll-result { color: #e67e22; }
  .roll-result { display: flex; align-items: center; gap: 6px; }
  .collector-footer { display: flex; align-items: center; justify-content: space-between; }
  .waiting-note { font-size: 12px; color: #888; }
  .btn-force { background: #e67e22; color: #fff; border: none; border-radius: 4px; padding: 3px 10px; cursor: pointer; font-size: 12px; }
  .resolved-banner { padding: 8px 12px; border-radius: 4px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .resolved-banner.pass { background: #d5f5e3; color: #1a6b3c; border: 1px solid #27ae60; }
  .resolved-banner.fail { background: #fadbd8; color: #7b241c; border: 1px solid #c0392b; }
</style>
