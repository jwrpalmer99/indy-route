<style>
    .traveler-manager .window-content {
        overflow: auto;
        padding: 12px 16px;
    }
    .traveler-manager form {
        display: grid;
        gap: 10px;
    }
    .traveler-manager .route-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }
    .traveler-manager .route-toolbar-actions {
        display: flex;
        gap: 6px;
    }
    .traveler-manager .route-list {
        display: grid;
        gap: 10px;
    }
    .traveler-manager .route-item {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: center;
        padding: 8px;
        border: 1px solid var(--color-border-light-2);
        border-radius: 8px;
        background: var(--color-bg);
    }
    .traveler-manager .route-item.selected {
        border-color: var(--color-border-highlight);
        box-shadow: 0 0 0 1px var(--color-border-highlight) inset;
    }
    .traveler-manager .route-name {
        width: 100%;
    }
    .traveler-manager .route-name-row {
        display: flex;
        align-items: center;
        gap: 6px;
        min-width: 0;
    }
    .traveler-manager .route-drag-handle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 14px;
        height: 22px;
        border-radius: 3px;
        color: var(--color-text-light-6);
        background: transparent;
        cursor: grab;
        flex: 0 0 auto;
    }
    .traveler-manager .route-drag-handle:active {
        cursor: grabbing;
    }
    .traveler-manager .route-drag-handle i {
        font-size: 0.7rem;
        opacity: 0.7;
    }
    .traveler-manager .route-name-row .route-name {
        flex: 1 1 auto;
        min-width: 0;
    }
    .traveler-manager .route-info {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        border-radius: 4px;
        border: 1px solid var(--color-border-light-2);
        color: var(--color-text-light-6);
        background: var(--color-bg-btn);
    }
    .tooltip.traveler-tooltip {
        max-width: 320px;
    }
    .traveler-manager .route-actions {
        display: flex;
        gap: 6px;
        justify-content: flex-end;
    }
    .traveler-manager .route-item.drag-over {
        border-color: var(--color-border-highlight);
        box-shadow: 0 0 0 2px var(--color-border-highlight) inset;
    }
    .traveler-manager .route-item.dragging {
        opacity: 0.65;
    }
    .traveler-manager .route-level-badge {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        padding: 1px 6px;
        border-radius: 10px;
        font-size: 0.7em;
        font-weight: 600;
        color: var(--color-text-light-highlight);
        background: var(--color-bg-highlight);
        border: 1px solid var(--color-border-highlight);
        white-space: nowrap;
        flex: 0 0 auto;
    }
    .traveler-manager .route-encounter-badge {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        padding: 1px 6px;
        border-radius: 10px;
        font-size: 0.7em;
        font-weight: 600;
        color: #fff;
        background: #7d3c00;
        border: 1px solid #a05000;
        white-space: nowrap;
        flex: 0 0 auto;
    }
    /* ── Proposals section ── */
    .traveler-manager .proposals-section {
        margin-top: 14px;
        border-top: 1px solid var(--color-border-light-2);
        padding-top: 10px;
    }
    .traveler-manager .proposals-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
        font-weight: 700;
        font-size: 0.9em;
    }
    .traveler-manager .proposals-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 18px;
        height: 18px;
        padding: 0 4px;
        border-radius: 9px;
        font-size: 0.75em;
        font-weight: 700;
        background: var(--color-border-highlight, #ff6400);
        color: #fff;
    }
    .traveler-manager .proposal-item {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: center;
        padding: 7px 8px;
        border: 1px solid var(--color-border-light-2);
        border-radius: 6px;
        background: var(--color-bg);
        margin-bottom: 6px;
    }
    .traveler-manager .proposal-info {
        min-width: 0;
    }
    .traveler-manager .proposal-info strong {
        font-size: 0.9em;
    }
    .traveler-manager .proposal-meta {
        font-size: 0.75em;
        color: var(--color-text-light-6);
        margin-top: 1px;
    }
    .traveler-manager .proposal-actions {
        display: flex;
        gap: 5px;
    }
    .traveler-manager .proposal-actions button {
        padding: 4px 8px;
        font-size: 0.85em;
    }
    .traveler-manager .proposal-actions button[data-action="approve-proposal"] {
        color: var(--color-level-success, #4caf50);
        border-color: var(--color-level-success, #4caf50);
    }
    .traveler-manager .proposal-actions button[data-action="reject-proposal"] {
        color: var(--color-level-error, #e53935);
        border-color: var(--color-level-error, #e53935);
    }
</style>

<form class="traveler-manager">
    <div class="route-toolbar">
        <button type="button" data-action="draw-route">Draw New Route</button>
        <div class="route-toolbar-actions">
            <button type="button" data-action="scene-settings" data-tooltip="Scene Distance Scale Override" data-tooltip-direction="DOWN">
                <i class="fa-solid fa-map"></i>
            </button>
            <button type="button" data-action="export-routes">Export Routes</button>
            <button type="button" data-action="import-routes">Import Routes</button>
        </div>
    </div>

    <div class="route-list">
        {{#if routes.length}}
            {{#each routes as |route|}}
                <div class="route-item {{#if (eq route.id ../selectedId)}}selected{{/if}}" data-action="select-route" data-route-id="{{route.id}}" data-draggable-route="{{route.id}}">
                    <div class="route-name-row">
                        <span class="route-drag-handle" draggable="true" data-drag-handle="true" data-tooltip="Drag to reorder">
                            <i class="fa-solid fa-grip-dots-vertical"></i>
                        </span>
                        <input class="route-name" type="text" data-action="rename-route" data-route-id="{{route.id}}" value="{{route.name}}" maxlength="50" />
                        {{#if route.levelName}}
                        <span class="route-level-badge" data-tooltip="Scene Level: {{route.levelName}}" data-tooltip-direction="UP">
                            <i class="fa-solid fa-layer-group"></i> {{route.levelName}}
                        </span>
                        {{/if}}
                        {{#if route.encounterCount}}
                        <span class="route-encounter-badge" data-tooltip="{{route.encounterCount}} encounter zone(s)" data-tooltip-direction="UP">
                            <i class="fa-solid fa-sword"></i> {{route.encounterCount}}
                        </span>
                        {{/if}}
                        {{#if route.lengthLabel}}
                        <span class="route-info" data-tooltip="{{route.lengthLabel}}" data-tooltip-direction="UP" data-tooltip-class="traveler-tooltip">
                            <i class="fa-solid fa-ruler"></i>
                        </span>
                        {{/if}}
                    </div>
                    <div class="route-actions">
                        <button type="button" data-action="play-route" data-route-id="{{route.id}}" data-tooltip="Play">
                            <i class="fa-solid fa-play"></i>
                        </button>
                        <button type="button" data-action="preview-route" data-route-id="{{route.id}}" data-tooltip="Preview">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                        <button type="button" data-action="persist-route" data-route-id="{{route.id}}" data-tooltip="Persist to Tile">
                            <i class="fa-solid fa-map"></i>
                        </button>
                        <button type="button" data-action="edit-points" data-route-id="{{route.id}}" data-tooltip="Edit Points">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </button>
                        <button type="button" data-action="edit-route" data-route-id="{{route.id}}" data-tooltip="Style">
                            <i class="fa-solid fa-sliders"></i>
                        </button>
                        <button type="button" data-action="clear-route" data-route-id="{{route.id}}" data-tooltip="Clear">
                            <i class="fa-solid fa-eraser"></i>
                        </button>
                        <button type="button" data-action="delete-route" data-route-id="{{route.id}}" data-tooltip="Delete">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>
            {{/each}}
        {{else}}
            <p class="hint">No routes recorded for this scene.</p>
        {{/if}}
    </div>

    {{!-- GM-only Proposals section (approval mode) --}}
    {{#if showProposals}}
    <div class="proposals-section">
        <div class="proposals-header">
            <i class="fa-solid fa-clock-rotate-left"></i>
            Player Proposals
            {{#if proposalCount}}
            <span class="proposals-badge">{{proposalCount}}</span>
            {{/if}}
        </div>

        {{#if proposals.length}}
            {{#each proposals as |p|}}
            <div class="proposal-item" data-proposal-id="{{p.id}}">
                <div class="proposal-info">
                    <strong>{{p.playerName}}</strong> &mdash; {{p.tokenName}}
                    <div class="proposal-meta">
                        <i class="fa-solid fa-clock"></i> {{p.timeAgo}}
                        &nbsp;&bull;&nbsp;
                        {{p.path.length}} waypoints
                        {{#if p.speedLabel}}
                        &nbsp;&bull;&nbsp;
                        <i class="fa-solid fa-person-walking"></i> {{p.speedLabel}}
                        {{/if}}
                    </div>
                </div>
                <div class="proposal-actions">
                    <button type="button"
                            data-action="preview-proposal"
                            data-proposal-id="{{p.id}}"
                            data-tooltip="Preview on canvas (4 s)"
                            data-tooltip-direction="UP">
                        <i class="fa-solid fa-eye"></i>
                    </button>
                    <button type="button"
                            data-action="approve-proposal"
                            data-proposal-id="{{p.id}}"
                            data-tooltip="Approve — play route"
                            data-tooltip-direction="UP">
                        <i class="fa-solid fa-check"></i>
                    </button>
                    <button type="button"
                            data-action="reject-proposal"
                            data-proposal-id="{{p.id}}"
                            data-tooltip="Reject"
                            data-tooltip-direction="UP">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            </div>
            {{/each}}
        {{else}}
            <p class="hint">No pending player route proposals.</p>
        {{/if}}
    </div>
    {{/if}}
</form>
