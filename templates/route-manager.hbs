<style>
    .traveler-manager .window-content {
        overflow: auto;
        padding: 12px 16px;
    }
    .traveler-manager form {
        display: grid;
        gap: 10px;
    }
    .traveler-manager .route-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }
    .traveler-manager .route-toolbar-actions {
        display: flex;
        gap: 6px;
    }
    .traveler-manager .route-list {
        display: grid;
        gap: 10px;
    }
    .traveler-manager .route-item {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        align-items: center;
        padding: 8px;
        border: 1px solid var(--color-border-light-2);
        border-radius: 8px;
        background: var(--color-bg);
    }
    .traveler-manager .route-item.selected {
        border-color: var(--color-border-highlight);
        box-shadow: 0 0 0 1px var(--color-border-highlight) inset;
    }
    .traveler-manager .route-name {
        width: 100%;
    }
    .traveler-manager .route-name-row {
        display: flex;
        align-items: center;
        gap: 6px;
        min-width: 0;
    }
    .traveler-manager .route-drag-handle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 14px;
        height: 22px;
        border-radius: 3px;
        color: var(--color-text-light-6);
        background: transparent;
        cursor: grab;
        flex: 0 0 auto;
    }
    .traveler-manager .route-drag-handle:active {
        cursor: grabbing;
    }
    .traveler-manager .route-drag-handle i {
        font-size: 0.7rem;
        opacity: 0.7;
    }
    .traveler-manager .route-name-row .route-name {
        flex: 1 1 auto;
        min-width: 0;
    }
    .traveler-manager .route-info {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        border-radius: 4px;
        border: 1px solid var(--color-border-light-2);
        color: var(--color-text-light-6);
        background: var(--color-bg-btn);
    }
    .tooltip.traveler-tooltip {
        max-width: 320px;
    }
    .traveler-manager .route-actions {
        display: flex;
        gap: 6px;
        justify-content: flex-end;
    }
    .traveler-manager .route-item.drag-over {
        border-color: var(--color-border-highlight);
        box-shadow: 0 0 0 2px var(--color-border-highlight) inset;
    }
    .traveler-manager .route-item.dragging {
        opacity: 0.65;
    }
    .traveler-manager .route-level-badge {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        padding: 1px 6px;
        border-radius: 10px;
        font-size: 0.7em;
        font-weight: 600;
        color: var(--color-text-light-highlight);
        background: var(--color-bg-highlight);
        border: 1px solid var(--color-border-highlight);
        white-space: nowrap;
        flex: 0 0 auto;
    }
</style>

<form class="traveler-manager">
    <div class="route-toolbar">
        <button type="button" data-action="draw-route">Draw New Route</button>
        <div class="route-toolbar-actions">
            <button type="button" data-action="export-routes">Export Routes</button>
            <button type="button" data-action="import-routes">Import Routes</button>
        </div>
    </div>

    <div class="route-list">
        {{#if routes.length}}
            {{#each routes as |route|}}
                <div class="route-item {{#if (eq route.id ../selectedId)}}selected{{/if}}" data-action="select-route" data-route-id="{{route.id}}" data-draggable-route="{{route.id}}">
                    <div class="route-name-row">
                        <span class="route-drag-handle" draggable="true" data-drag-handle="true" data-tooltip="Drag to reorder">
                            <i class="fa-solid fa-grip-dots-vertical"></i>
                        </span>
                        <input class="route-name" type="text" data-action="rename-route" data-route-id="{{route.id}}" value="{{route.name}}" maxlength="50" />
                        {{#if route.levelName}}
                        <span class="route-level-badge" data-tooltip="Scene Level: {{route.levelName}}" data-tooltip-direction="UP">
                            <i class="fa-solid fa-layer-group"></i> {{route.levelName}}
                        </span>
                        {{/if}}
                        {{#if route.lengthLabel}}
                        <span class="route-info" data-tooltip="{{route.lengthLabel}}" data-tooltip-direction="UP" data-tooltip-class="traveler-tooltip">
                            <i class="fa-solid fa-ruler"></i>
                        </span>
                        {{/if}}
                    </div>
                    <div class="route-actions">
                        <button type="button" data-action="play-route" data-route-id="{{route.id}}" data-tooltip="Play">
                            <i class="fa-solid fa-play"></i>
                        </button>
                        <button type="button" data-action="preview-route" data-route-id="{{route.id}}" data-tooltip="Preview">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                        <button type="button" data-action="persist-route" data-route-id="{{route.id}}" data-tooltip="Persist to Tile">
                            <i class="fa-solid fa-map"></i>
                        </button>
                        <button type="button" data-action="edit-points" data-route-id="{{route.id}}" data-tooltip="Edit Points">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </button>
                        <button type="button" data-action="edit-route" data-route-id="{{route.id}}" data-tooltip="Style">
                            <i class="fa-solid fa-sliders"></i>
                        </button>
                        <button type="button" data-action="clear-route" data-route-id="{{route.id}}" data-tooltip="Clear">
                            <i class="fa-solid fa-eraser"></i>
                        </button>
                        <button type="button" data-action="delete-route" data-route-id="{{route.id}}" data-tooltip="Delete">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>
            {{/each}}
        {{else}}
            <p class="hint">No routes recorded for this scene.</p>
        {{/if}}
    </div>
</form>
