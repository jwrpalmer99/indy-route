# ── Node ────────────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── Test output ─────────────────────────────────────────────────────────────
coverage/
playwright-traces/
playwright-report/
test-results/

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── Environment / secrets ────────────────────────────────────────────────────
# .env.example IS committed (it's a safe template with no real values).
# All other .env variants are ignored.
.env*
!.env.example

# ── Foundry world runtime data ───────────────────────────────────────────────
# Only tests/world/world.json is committed (the world manifest).
# Everything else under tests/world/ is generated at runtime by Foundry.
tests/world/**
!tests/world/world.json

# ── OS / editor noise ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.user
